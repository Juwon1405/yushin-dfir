  "ground_truth_findings": [
    {
      "finding_id": "F-HADI1-001",
      "category": "initial_access",
      "claim": "Initial access via Apache web service (port 80/443)",
      "evidence_path": "/var/log/apache2/access.log",
      "artifact_type": "web_log",
      "host_path": "/var/log/apache2/access.log",
      "expected_dart_mcp_function": "parse_linux_text_log",
      "mitre_attack": ["T1190"],
      "rationale": "Apache access log shows the first attacker request as the entry vector."
    },
    {
      "finding_id": "F-HADI1-002",
      "category": "execution",
      "claim": "Web shell uploaded to /var/www/html/",
      "evidence_path": "/var/www/html/*.php",
      "artifact_type": "web_shell",
      "host_path": "/var/www/html/",
      "expected_dart_mcp_function": "detect_web_shell_indicators",
      "mitre_attack": ["T1505.003"],
      "rationale": "PHP web shell file dropped in Apache document root, accessible via HTTP."
    },
    {
      "finding_id": "F-HADI1-003",
      "category": "persistence",
      "claim": "Cron-based persistence mechanism installed",
      "evidence_path": "/etc/crontab and /var/spool/cron/crontabs/",
      "artifact_type": "cron_job",
      "host_path": "/etc/crontab",
      "expected_dart_mcp_function": "parse_linux_cron_jobs",
      "mitre_attack": ["T1053.003"],
      "rationale": "Attacker-modified cron job re-establishes shell connection at interval."
    },
    {
      "finding_id": "F-HADI1-004",
      "category": "credential_access",
      "claim": "Attempted /etc/shadow access logged",
      "evidence_path": "/var/log/auth.log",
      "artifact_type": "auth_log",
      "host_path": "/var/log/auth.log",
      "expected_dart_mcp_function": "parse_linux_text_log",
      "mitre_attack": ["T1003.008"],
      "rationale": "sudo and su authentication events show privilege escalation attempts."
    },
    {
      "finding_id": "F-HADI1-005",
      "category": "discovery",
      "claim": "Attacker enumerated system via /root/.bash_history",
      "evidence_path": "/root/.bash_history",
      "artifact_type": "shell_history",
      "host_path": "/root/.bash_history",
      "expected_dart_mcp_function": "parse_linux_shell_history",
      "mitre_attack": ["T1083", "T1057", "T1082"],
      "rationale": "Recovered commands show id, uname, netstat, ps reconnaissance sequence."
    },
    {
      "finding_id": "F-HADI1-006",
      "category": "lateral_movement",
      "claim": "Outbound connection initiated to attacker C2",
      "evidence_path": "/var/log/syslog and netstat",

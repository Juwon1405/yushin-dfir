      "host_path": "/var/log/syslog",
      "expected_dart_mcp_function": "parse_linux_text_log",
      "mitre_attack": ["T1071.001"],
      "rationale": "Reverse-shell connection appears in process listing and syslog."
    },
    {
      "finding_id": "F-HADI1-007",
      "category": "exfiltration",
      "claim": "Data staged in /tmp before exfil",
      "evidence_path": "/tmp/ working directory contents",
      "artifact_type": "filesystem_artifact",
      "host_path": "/tmp/",
      "expected_dart_mcp_function": "enumerate_filesystem_anomalies",
      "mitre_attack": ["T1074.001"],
      "rationale": "Archive file created in /tmp containing /etc/passwd, /etc/shadow, web configs."
